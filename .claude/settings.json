{
  "permissions": {
    "allow": [
      "Bash(npm run:*)",
      "Bash(npx:*)",
      "Bash(npm install:*)",
      "Bash(npm uninstall:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Read",
      "Glob",
      "Grep"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_response.filePath // .tool_input.file_path' | { read -r f; case \"$f\" in *.ts|*.tsx|*.js|*.jsx|*.css|*.json) npx --yes prettier --write \"$f\" 2>/dev/null;; esac; } || true",
            "timeout": 15,
            "statusMessage": "Formatting..."
          }
        ]
      }
    ]
  }
}
